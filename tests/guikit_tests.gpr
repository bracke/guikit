with "config/guikit_tests_config.gpr";
project Guikit_Tests is

   for Source_Dirs use ("tests/src/", "config/");
   for Object_Dir use "obj/" & Guikit_Tests_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("guikit_tests.adb");

   package Compiler is
      for Default_Switches ("Ada") use
        Guikit_Tests_Config.Ada_Compiler_Switches & ("-gnat2022", "-gnatyM120", "-gnatX", "-gnatwU");
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Linker is
      for Default_Switches ("Ada") use
        ("-lvulkan", "-lz", "-lgdk_pixbuf-2.0", "-lgobject-2.0", "-lglib-2.0");
   end Linker;

   package Builder is
      for Executable ("guikit_tests.adb") use "guikit_tests";
   end Builder;

end Guikit_Tests;
