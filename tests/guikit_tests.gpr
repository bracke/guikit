with "config/guikit_tests_config.gpr";
project Guikit_Tests is

   for Source_Dirs use ("tests/src/", "config/");
   for Object_Dir use "obj/" & Guikit_Tests_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("guikit_tests.adb");

   package Compiler is
      for Default_Switches ("Ada") use
        Guikit_Tests_Config.Ada_Compiler_Switches & ("-gnat2022", "-gnatyM120", "-gnatX", "-gnatwU");
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Linker is
      --  "-lz" was here, and nothing wanted it: guikit calls no C zlib, and the zlib
      --  sibling crate implements every codec it supports in Ada and links none.
      case Guikit_Tests_Config.Alire_Host_OS is
         when "windows" =>
            --  The Vulkan loader is vulkan-1.dll on Windows, so the library is
            --  vulkan-1, not vulkan. Asking for -lvulkan there simply does not link.
            for Default_Switches ("Ada") use
              ("-lvulkan-1", "-lgdk_pixbuf-2.0", "-lgobject-2.0", "-lglib-2.0");
         when others =>
            for Default_Switches ("Ada") use
              ("-lvulkan", "-lgdk_pixbuf-2.0", "-lgobject-2.0", "-lglib-2.0");
      end case;
   end Linker;

   package Builder is
      for Executable ("guikit_tests.adb") use "guikit_tests";
   end Builder;

end Guikit_Tests;
